// Avmall — Prisma schema
// Source of truth for the data model. See CLAUDE.md §6 for conventions:
// — UUIDs, snake_case in SQL / camelCase in Prisma, money as integer kobo (BigInt
//   for amounts that may exceed ~21M Naira), timestamptz with UTC, soft deletes
//   via archived_at, audit_logs append-only.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [pg_trgm, pgcrypto]
}

// ─── Stores (physical locations) ─────────────────────────────────────────

model Store {
  id        String   @id @default(uuid()) @db.Uuid
  name      String // "Ikoyi flagship"
  slug      String   @unique // storefront URL + dropdown key
  /// The bare storefront URL lands on the main store. Exactly one is main.
  isMain    Boolean  @default(false) @map("is_main")
  active    Boolean  @default(true)
  phone     String?
  email     String?
  address   String? // street line
  city      String? // LGA
  state     String? // Nigerian state
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  staff        User[]
  stock        StoreStock[]
  orders       Order[]
  reservations StockReservation[]

  @@map("stores")
}

/// Per-store inventory. A product is sellable at a store when it has a row
/// here. Replaces the single global ProductVariant.onHand/reserved.
model StoreStock {
  id        String   @id @default(uuid()) @db.Uuid
  storeId   String   @map("store_id") @db.Uuid
  variantId String   @map("variant_id") @db.Uuid
  onHand    Int      @default(0) @map("on_hand")
  reserved  Int      @default(0)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  store   Store          @relation(fields: [storeId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([storeId, variantId])
  @@index([variantId])
  @@map("store_stock")
}

// ─── Staff & RBAC ────────────────────────────────────────────────────────

enum StaffRole {
  super_admin
  manager
  sales
  inventory
  support
}

/// Dynamic role with an explicit permission set. The 5 enum-named roles are
/// seeded as system roles (isSystem — editable but not deletable); custom roles
/// can be created freely. The legacy User.role enum stays as a fallback.
model Role {
  id          String   @id @default(uuid()) @db.Uuid
  name        String // "Manager", "Warehouse lead"
  slug        String   @unique // "manager", "warehouse-lead"
  description String?
  isSystem    Boolean  @default(false) @map("is_system")
  /// Permission keys — see PermissionKey in lib/permissions.ts.
  permissions String[] @default([])
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  users       User[]
  invitations StaffInvitation[]

  @@map("roles")
}

model User {
  id            String    @id @default(uuid()) @db.Uuid
  email         String    @unique
  name          String
  passwordHash  String    @map("password_hash")
  /// Legacy coarse role enum — kept as a fallback. Permissions resolve from
  /// roleId (the dynamic Role) when set, which it is for all migrated users.
  role          StaffRole
  roleId        String?   @map("role_id") @db.Uuid
  active        Boolean   @default(true)
  /// Home store. null = HQ / all-stores (e.g. super_admin). The POS sells from
  /// this store; cross-store visibility is gated by the stores.view_all perm.
  storeId       String?   @map("store_id") @db.Uuid
  totpSecret    String?   @map("totp_secret")
  totpEnabled   Boolean   @default(false) @map("totp_enabled")
  lastSeenAt    DateTime? @map("last_seen_at") @db.Timestamptz
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  assignedRole      Role?           @relation(fields: [roleId], references: [id])
  store             Store?          @relation(fields: [storeId], references: [id])
  ordersCreated     Order[]         @relation("OrderCreatedBy")
  paymentsRecorded  OrderPayment[]  @relation("PaymentRecordedBy")
  installmentPlansCreated InstallmentPlan[] @relation("InstallmentPlanCreatedBy")
  notes             OrderNote[]
  auditLogs         AuditLog[]
  invitationsSent   StaffInvitation[] @relation("StaffInvitedBy")
  passwordResets    PasswordReset[]

  @@index([storeId])
  @@index([roleId])
  @@map("users")
}

// ─── Customers ───────────────────────────────────────────────────────────

model Customer {
  id            String    @id @default(uuid()) @db.Uuid
  /// E.164 — always stored with +234 prefix. See lib/phone.ts.
  phone         String    @unique
  email         String?
  name          String
  segments      String[]  @default([])
  blacklisted   Boolean   @default(false)
  blacklistReason String? @map("blacklist_reason")
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  addresses     CustomerAddress[]
  orders        Order[]
  returns       Return[]
  conversations AiConversation[]
  otpCodes      OtpCode[]

  @@index([phone])
  @@index([email])
  @@map("customers")
}

model CustomerAddress {
  id          String   @id @default(uuid()) @db.Uuid
  customerId  String   @map("customer_id") @db.Uuid
  label       String   // "Home", "Office"
  recipient   String
  phone       String
  line1       String
  line2       String?
  city        String   // LGA
  state       String   // Nigerian state
  isDefault   Boolean  @default(false) @map("is_default")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@map("customer_addresses")
}

// ─── Products & inventory ────────────────────────────────────────────────

model Category {
  id        String   @id @default(uuid()) @db.Uuid
  slug      String   @unique
  name      String
  /// Display order on the storefront.
  position  Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  products  Product[]

  @@map("categories")
}

model Product {
  id              String    @id @default(uuid()) @db.Uuid
  slug            String    @unique
  name            String
  brand           String
  shortDesc       String    @map("short_desc")
  longDesc        String    @default("") @map("long_desc")
  categoryId      String    @map("category_id") @db.Uuid
  /// Display tone hex / gradient for the imagery backdrop.
  themeBg         String?   @map("theme_bg")
  /// Money — kobo. Use BigInt to support items > ~21M Naira.
  priceKobo       BigInt    @map("price_kobo")
  saleKobo        BigInt?   @map("sale_kobo")
  saleActive      Boolean   @default(false) @map("sale_active")
  /// Internal-audit cost of goods, in kobo. Never exposed on the storefront.
  /// Profit displays use this to compute margin.
  costPriceKobo   BigInt    @default(0) @map("cost_price_kobo")
  /// Allow customers to propose a price via the AI / WhatsApp.
  negotiate       Boolean   @default(false)
  /// Optional per-product negotiation cap. Either a flat kobo floor OR a max
  /// % off the retail price. Both null = fall back to AiSettings global rule.
  negotiateFloorKobo BigInt? @map("negotiate_floor_kobo")
  negotiateMaxPct   Int?    @map("negotiate_max_pct")
  /// Variant option-group labels. Null when the product has only the default
  /// variant. Up to two groups (e.g. "Size" × "Color").
  option1Name     String?   @map("option1_name")
  option2Name     String?   @map("option2_name")
  /// Pre-order only — won't reserve regular stock.
  preorder        Boolean   @default(false)
  moq             Int?
  eta             String?
  /// Soft delete — archived products are hidden from the storefront but
  /// remain on past orders.
  archivedAt      DateTime? @map("archived_at") @db.Timestamptz
  published       Boolean   @default(false)
  featured        Boolean   @default(false)
  /// Free-form tags ("handmade", "small-batch").
  tags            String[]  @default([])
  /// SEO meta description (falls back to shortDesc).
  metaDescription String?   @map("meta_description")
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  category        Category         @relation(fields: [categoryId], references: [id])
  variants        ProductVariant[]
  images          ProductImage[]
  bulkTiers       BulkTier[]
  orderLines      OrderLine[]
  stockReservations StockReservation[]
  stockNotifications StockNotification[]

  @@index([categoryId])
  @@index([archivedAt])
  @@index([slug])
  @@map("products")
}

model ProductVariant {
  id          String   @id @default(uuid()) @db.Uuid
  productId   String   @map("product_id") @db.Uuid
  label       String   // Composed display, e.g. "Small / Red"
  sku         String   @unique
  /// Optional variant-specific override; null = inherit from product.
  priceKobo   BigInt?  @map("price_kobo")
  /// Values for the parent product's option groups.
  /// option1Value matches Product.option1Name; option2Value matches option2Name.
  option1Value String? @map("option1_value")
  option2Value String? @map("option2_value")
  position    Int      @default(0)
  archivedAt  DateTime? @map("archived_at") @db.Timestamptz
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  product     Product            @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderLines  OrderLine[]
  stockReservations StockReservation[]
  storeStock  StoreStock[]

  @@index([productId])
  @@map("product_variants")
}

model ProductImage {
  id        String   @id @default(uuid()) @db.Uuid
  productId String   @map("product_id") @db.Uuid
  /// R2 key — public URL composed as `${R2_PUBLIC_URL}/${key}`.
  key       String
  alt       String?
  position  Int      @default(0)
  isPrimary Boolean  @default(false) @map("is_primary")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_images")
}

enum BulkTierType {
  percentage
  fixed
}

model BulkTier {
  id        String        @id @default(uuid()) @db.Uuid
  productId String        @map("product_id") @db.Uuid
  min       Int
  max       Int?
  type      BulkTierType
  /// Percent (0-100) when type=percentage, kobo per unit when type=fixed.
  value     Int
  createdAt DateTime      @default(now()) @map("created_at") @db.Timestamptz

  product   Product       @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("bulk_tiers")
}

// ─── Stock reservations ──────────────────────────────────────────────────

enum StockReservationStatus {
  active
  released
  consumed
}

model StockReservation {
  id          String                  @id @default(uuid()) @db.Uuid
  storeId     String                  @map("store_id") @db.Uuid
  productId   String                  @map("product_id") @db.Uuid
  variantId   String?                 @map("variant_id") @db.Uuid
  orderId     String?                 @map("order_id") @db.Uuid
  quantity    Int
  expiresAt   DateTime                @map("expires_at") @db.Timestamptz
  status      StockReservationStatus  @default(active)
  createdAt   DateTime                @default(now()) @map("created_at") @db.Timestamptz

  store       Store                   @relation(fields: [storeId], references: [id])
  product     Product                 @relation(fields: [productId], references: [id])
  variant     ProductVariant?         @relation(fields: [variantId], references: [id])
  order       Order?                  @relation(fields: [orderId], references: [id])

  @@index([expiresAt, status])
  @@index([orderId])
  @@index([storeId, variantId])
  @@map("stock_reservations")
}

// ─── Orders ──────────────────────────────────────────────────────────────

enum OrderStatus {
  pending
  confirmed
  processing
  shipped
  delivered
  cancelled
  refunded
}

enum PaymentStatus {
  unpaid
  partial
  paid
  refunded
}

enum OrderSource {
  web
  whatsapp
  phone
  walkin
  ai
}

model Order {
  id              String        @id @default(uuid()) @db.Uuid
  /// Customer-facing order number, AVM-YYYY-XXXXXXXX (Postgres sequence).
  number          String        @unique
  customerId      String?       @map("customer_id") @db.Uuid
  /// Store the order belongs to (web: selected store; POS: operator's store).
  storeId         String?       @map("store_id") @db.Uuid
  status          OrderStatus   @default(pending)
  paymentStatus   PaymentStatus @default(unpaid) @map("payment_status")
  source          OrderSource

  // Shipping address snapshot (captured at order time so address edits later
  // don't rewrite history).
  shipName        String        @map("ship_name")
  shipPhone       String        @map("ship_phone")
  shipLine1       String        @map("ship_line1")
  shipLine2       String?       @map("ship_line2")
  shipCity        String        @map("ship_city")
  shipState       String        @map("ship_state")
  shippingZoneId  String?       @map("shipping_zone_id") @db.Uuid

  // Totals (kobo) — recomputed on every mutation; never trusted from client.
  subtotalKobo     BigInt @default(0) @map("subtotal_kobo")
  bulkDiscountKobo BigInt @default(0) @map("bulk_discount_kobo")
  couponDiscountKobo BigInt @default(0) @map("coupon_discount_kobo")
  manualDiscountKobo BigInt @default(0) @map("manual_discount_kobo")
  shippingKobo     BigInt @default(0) @map("shipping_kobo")
  totalKobo        BigInt @default(0) @map("total_kobo")
  paidKobo         BigInt @default(0) @map("paid_kobo")

  appliedCouponCode String? @map("applied_coupon_code")

  createdById     String?       @map("created_by_id") @db.Uuid
  customerNote    String?       @map("customer_note")
  /// ISO from cart-quote — server validates totals before checkout.
  quoteId         String?       @map("quote_id")
  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime      @updatedAt @map("updated_at") @db.Timestamptz
  shippedAt       DateTime?     @map("shipped_at") @db.Timestamptz
  deliveredAt     DateTime?     @map("delivered_at") @db.Timestamptz
  cancelledAt     DateTime?     @map("cancelled_at") @db.Timestamptz

  customer        Customer?     @relation(fields: [customerId], references: [id])
  store           Store?        @relation(fields: [storeId], references: [id])
  createdBy       User?         @relation("OrderCreatedBy", fields: [createdById], references: [id])
  shippingZone    ShippingZone? @relation(fields: [shippingZoneId], references: [id])
  lines           OrderLine[]
  payments        OrderPayment[]
  reservations    StockReservation[]
  returns         Return[]
  notes           OrderNote[]
  conversations   AiConversation[]
  installmentPlan InstallmentPlan?

  @@index([customerId])
  @@index([storeId])
  @@index([status])
  @@index([paymentStatus])
  @@index([createdAt])
  @@map("orders")
}

model OrderLine {
  id           String  @id @default(uuid()) @db.Uuid
  orderId      String  @map("order_id") @db.Uuid
  productId    String  @map("product_id") @db.Uuid
  variantId    String? @map("variant_id") @db.Uuid
  /// Snapshotted at order time so future product edits don't rewrite history.
  nameSnapshot    String @map("name_snapshot")
  variantSnapshot String? @map("variant_snapshot")
  skuSnapshot     String  @map("sku_snapshot")
  quantity        Int
  unitKobo        BigInt @map("unit_kobo")
  /// Per-line discount from bulk tier.
  bulkDiscountKobo BigInt @default(0) @map("bulk_discount_kobo")
  bulkTierLabel   String? @map("bulk_tier_label")
  preorder        Boolean @default(false)
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz

  order        Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product      Product        @relation(fields: [productId], references: [id])
  variant      ProductVariant? @relation(fields: [variantId], references: [id])
  returnLines  ReturnLine[]

  @@index([orderId])
  @@map("order_lines")
}

enum PaymentMethod {
  nuqood
  bank_transfer
  pos
  cash
}

enum PaymentRecordStatus {
  pending
  completed
  failed
  reversed
}

model OrderPayment {
  id          String              @id @default(uuid()) @db.Uuid
  orderId     String              @map("order_id") @db.Uuid
  method      PaymentMethod
  amountKobo  BigInt              @map("amount_kobo")
  /// Nuqood/bank transaction reference.
  reference   String?
  status      PaymentRecordStatus @default(pending)
  recordedById String?            @map("recorded_by_id") @db.Uuid
  note        String?
  createdAt   DateTime            @default(now()) @map("created_at") @db.Timestamptz

  order       Order               @relation(fields: [orderId], references: [id], onDelete: Cascade)
  recordedBy  User?               @relation("PaymentRecordedBy", fields: [recordedById], references: [id])

  @@index([orderId])
  @@map("order_payments")
}

/// Buy-now-pay-later installment plan on an order. Flexible balance: the
/// customer receives the goods and pays the balance down over time; staff
/// record each payment through the normal OrderPayment ledger. The plan is
/// "completed" when paid_kobo reaches total_kobo. One plan per order.
enum InstallmentPlanStatus {
  active
  completed
  cancelled
  defaulted
}

model InstallmentPlan {
  id               String                @id @default(uuid()) @db.Uuid
  orderId          String                @unique @map("order_id") @db.Uuid
  status           InstallmentPlanStatus @default(active)
  /// Optional minimum amount (kobo) a single payment must meet.
  minPaymentKobo   BigInt?               @map("min_payment_kobo")
  /// Optional date the balance is expected to reach zero (drives overdue).
  targetPayoffDate DateTime?             @map("target_payoff_date") @db.Timestamptz
  note             String?
  createdById      String?               @map("created_by_id") @db.Uuid
  /// Last reminder send, for cadence throttling.
  lastReminderAt   DateTime?             @map("last_reminder_at") @db.Timestamptz
  createdAt        DateTime              @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime              @updatedAt @map("updated_at") @db.Timestamptz

  order            Order                 @relation(fields: [orderId], references: [id], onDelete: Cascade)
  createdBy        User?                 @relation("InstallmentPlanCreatedBy", fields: [createdById], references: [id])

  @@index([status])
  @@map("installment_plans")
}

model OrderNote {
  id        String   @id @default(uuid()) @db.Uuid
  orderId   String   @map("order_id") @db.Uuid
  authorId  String?  @map("author_id") @db.Uuid
  text      String
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  author    User?    @relation(fields: [authorId], references: [id])

  @@index([orderId])
  @@map("order_notes")
}

// ─── Returns ─────────────────────────────────────────────────────────────

enum ReturnStatus {
  requested
  approved
  in_transit
  received
  refunded
  rejected
}

enum ReturnCondition {
  unopened
  used
  damaged
}

enum ReturnRefundMethod {
  original
  transfer
}

model Return {
  id              String              @id @default(uuid()) @db.Uuid
  /// Customer-facing return ID, RET-XXXXXXX.
  number          String              @unique
  orderId         String              @map("order_id") @db.Uuid
  customerId      String              @map("customer_id") @db.Uuid
  status          ReturnStatus        @default(requested)
  reason          String
  refundKobo      BigInt              @default(0) @map("refund_kobo")
  refundMethod    ReturnRefundMethod  @default(original) @map("refund_method")
  /// Set when the originating order was delivered > 14 days ago.
  outsideWindow   Boolean             @default(false) @map("outside_window")
  /// Set if every line on the originating order has already been returned.
  fullyReturned   Boolean             @default(false) @map("fully_returned")
  internalNote    String?             @map("internal_note")
  photos          String[]            @default([])
  createdAt       DateTime            @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime            @updatedAt @map("updated_at") @db.Timestamptz

  order           Order               @relation(fields: [orderId], references: [id])
  customer        Customer            @relation(fields: [customerId], references: [id])
  lines           ReturnLine[]

  @@index([orderId])
  @@index([status])
  @@map("returns")
}

model ReturnLine {
  id              String          @id @default(uuid()) @db.Uuid
  returnId        String          @map("return_id") @db.Uuid
  orderLineId     String          @map("order_line_id") @db.Uuid
  quantity        Int
  condition       ReturnCondition
  /// Damaged items default to false (write off).
  restock         Boolean         @default(false)
  refundKobo      BigInt          @map("refund_kobo")
  createdAt       DateTime        @default(now()) @map("created_at") @db.Timestamptz

  return          Return          @relation(fields: [returnId], references: [id], onDelete: Cascade)
  orderLine       OrderLine       @relation(fields: [orderLineId], references: [id])

  @@map("return_lines")
}

// ─── Discounts ───────────────────────────────────────────────────────────

enum DiscountKind {
  coupon
  automatic
}

enum DiscountValueType {
  percentage
  fixed
  free_shipping
}

model Discount {
  id             String            @id @default(uuid()) @db.Uuid
  /// Coupon code (uppercase). Null for automatic discounts.
  code           String?           @unique
  kind           DiscountKind
  name           String
  valueType      DiscountValueType @map("value_type")
  /// Percent (0-100) for percentage, kobo for fixed, ignored for free_shipping.
  value          Int               @default(0)
  scope          String            @default("all") // "all", "category:beauty", "segment:wholesale"
  usage          Int               @default(0)
  usageLimit     Int?              @map("usage_limit")
  validFrom      DateTime?         @map("valid_from") @db.Timestamptz
  validUntil     DateTime?         @map("valid_until") @db.Timestamptz
  active         Boolean           @default(true)
  /// Locked once `usage > 0` per CLAUDE.md §20 — value & scope become immutable.
  locked         Boolean           @default(false)
  createdAt      DateTime          @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime          @updatedAt @map("updated_at") @db.Timestamptz

  @@map("discounts")
}

// ─── Shipping ────────────────────────────────────────────────────────────

model ShippingZone {
  id              String   @id @default(uuid()) @db.Uuid
  name            String
  /// Nigerian states this zone covers.
  states          String[]
  baseRateKobo    BigInt   @map("base_rate_kobo")
  /// Order subtotal above which shipping is free; null = never.
  freeOverKobo    BigInt?  @map("free_over_kobo")
  etaDays         String   @map("eta_days")
  /// Deprecated — priority/overlap resolution was removed (one price per state
  /// now). Kept at default 100 to avoid a migration; safe to drop later.
  priority        Int      @default(100)
  active          Boolean  @default(true)
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz

  orders          Order[]

  @@map("shipping_zones")
}

model FallbackShipping {
  id            String  @id @default(uuid()) @db.Uuid
  enabled       Boolean @default(true)
  flatRateKobo  BigInt  @map("flat_rate_kobo")
  etaDays       String  @map("eta_days")
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@map("fallback_shipping")
}

/// Delivery couriers the business uses. Managed live from the admin shipping
/// tab. `isPrimary` marks the default courier; `active` toggles availability.
model Courier {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  active      Boolean  @default(true)
  isPrimary   Boolean  @default(false) @map("is_primary")
  phone       String?
  /// Tracking URL template, optionally with a `{tracking}` placeholder.
  trackingUrl String?  @map("tracking_url")
  note        String?
  position    Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@map("couriers")
}

// ─── Cart (server-side, replaces client mock store in Phase 4) ───────────

model Cart {
  id            String     @id @default(uuid()) @db.Uuid
  /// Anonymous carts have no customer.
  customerId    String?    @map("customer_id") @db.Uuid
  /// Set when an Idempotency-Key has been used to lock a quote in.
  lastQuoteId   String?    @map("last_quote_id")
  createdAt     DateTime   @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime   @updatedAt @map("updated_at") @db.Timestamptz
  abandonedAt   DateTime?  @map("abandoned_at") @db.Timestamptz

  items         CartItem[]

  @@map("carts")
}

model CartItem {
  id          String   @id @default(uuid()) @db.Uuid
  cartId      String   @map("cart_id") @db.Uuid
  productId   String   @map("product_id") @db.Uuid
  variantId   String?  @map("variant_id") @db.Uuid
  quantity    Int
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  cart        Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)

  @@unique([cartId, productId, variantId])
  @@index([cartId])
  @@map("cart_items")
}

// ─── OTP (customer auth) ─────────────────────────────────────────────────

model OtpCode {
  id          String   @id @default(uuid()) @db.Uuid
  /// Phone (E.164) or email, normalized.
  identifier  String
  customerId  String?  @map("customer_id") @db.Uuid
  /// Bcrypt hash of the 6-digit code.
  codeHash    String   @map("code_hash")
  attempts    Int      @default(0)
  expiresAt   DateTime @map("expires_at") @db.Timestamptz
  consumedAt  DateTime? @map("consumed_at") @db.Timestamptz
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  customer    Customer? @relation(fields: [customerId], references: [id])

  @@index([identifier, expiresAt])
  @@map("otp_codes")
}

// ─── AI conversations ────────────────────────────────────────────────────

enum AiConversationStatus {
  active
  handoff_pending
  handoff_active
  closed
}

enum AiMessageRole {
  user
  ai
  staff
}

enum AiChannel {
  whatsapp
  web
}

model AiConversation {
  id             String                @id @default(uuid()) @db.Uuid
  customerId     String?               @map("customer_id") @db.Uuid
  orderId        String?               @map("order_id") @db.Uuid
  channel        AiChannel
  status         AiConversationStatus  @default(active)
  assignedStaffId String?              @map("assigned_staff_id") @db.Uuid
  startedAt      DateTime              @default(now()) @map("started_at") @db.Timestamptz
  closedAt       DateTime?             @map("closed_at") @db.Timestamptz
  /// Set when SLA breached and not yet claimed.
  slaBreachedAt  DateTime?             @map("sla_breached_at") @db.Timestamptz

  customer       Customer?             @relation(fields: [customerId], references: [id])
  order          Order?                @relation(fields: [orderId], references: [id])
  messages       AiMessage[]

  @@index([status])
  @@map("ai_conversations")
}

model AiMessage {
  id              String         @id @default(uuid()) @db.Uuid
  conversationId  String         @map("conversation_id") @db.Uuid
  role            AiMessageRole
  text            String
  /// Tool calls + results from the LLM orchestrator.
  toolCalls       Json?          @map("tool_calls")
  createdAt       DateTime       @default(now()) @map("created_at") @db.Timestamptz

  conversation    AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@map("ai_messages")
}

// ─── Audit log (append-only) ─────────────────────────────────────────────

model AuditLog {
  id          String   @id @default(uuid()) @db.Uuid
  actorUserId String?  @map("actor_user_id") @db.Uuid
  actorType   String   @map("actor_type") // "staff", "customer", "ai", "system"
  action      String   // "order.cancel", "customer.blacklist", "product.price.change"
  entityType  String   @map("entity_type")
  entityId    String   @map("entity_id")
  before      Json?
  after       Json?
  /// Request metadata: ip, user_agent, channel.
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  actor       User?    @relation(fields: [actorUserId], references: [id])

  @@index([entityType, entityId])
  @@index([actorUserId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─── AI settings (singleton) ─────────────────────────────────────────────

/// Singleton — one row only (key = "default"). Used by the AI agent's
/// negotiation tool when a product doesn't override its own floor.
model AiSettings {
  key                   String   @id @default("default")
  /// Global negotiation cap as a percentage of retail. e.g. 10 = AI may
  /// settle as low as 90 % of price. Used when a product has no override.
  globalNegotiateMaxPct Int      @default(10) @map("global_negotiate_max_pct")
  /// Master toggle — when false, AI cannot accept *any* counter-offer.
  negotiationEnabled    Boolean  @default(true) @map("negotiation_enabled")
  updatedAt             DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@map("ai_settings")
}

// ─── Staff invitations ───────────────────────────────────────────────────

/// One row per outstanding invitation. Burnt-on-accept (acceptedAt set + the
/// token is single-use). Expired rows can be reaped on a schedule but aren't
/// dangerous to leave around — the route checks expiresAt + acceptedAt.
model StaffInvitation {
  id            String    @id @default(uuid()) @db.Uuid
  email         String
  name          String
  role          StaffRole
  roleId        String?   @map("role_id") @db.Uuid
  /// Long opaque secret in the invite link. Hashed at rest would be safer
  /// but the field's already protected by HTTPS + single-use semantics.
  token         String    @unique
  invitedById   String?   @map("invited_by_id") @db.Uuid
  expiresAt     DateTime  @map("expires_at") @db.Timestamptz
  acceptedAt    DateTime? @map("accepted_at") @db.Timestamptz
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz

  invitedBy     User?     @relation("StaffInvitedBy", fields: [invitedById], references: [id])
  assignedRole  Role?     @relation(fields: [roleId], references: [id])

  @@index([email])
  @@index([expiresAt])
  @@map("staff_invitations")
}

// ─── Newsletter ───────────────────────────────────────────────────────────

/// Storefront newsletter signups. Source = where on the site they signed up
/// from (e.g. "homepage-footer"). Unique on email so re-submits are no-ops.
model NewsletterSubscriber {
  id             String    @id @default(uuid()) @db.Uuid
  email          String    @unique
  source         String?
  unsubscribedAt DateTime? @map("unsubscribed_at") @db.Timestamptz
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz

  @@map("newsletter_subscribers")
}

// ─── Restock notifications ────────────────────────────────────────────────

/// "Notify me when this is back" signups from the PDP. Either email or phone
/// is captured (preferably email; cheaper to notify). Staff fires the email
/// from /admin/products once stock comes back. Postgres treats NULLs as
/// distinct, so the partial uniqueness still allows the same product to
/// have many anonymous phone-only or email-only entries.
model StockNotification {
  id         String    @id @default(uuid()) @db.Uuid
  productId  String    @map("product_id") @db.Uuid
  email      String?
  phone      String?
  source     String?
  notifiedAt DateTime? @map("notified_at") @db.Timestamptz
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz

  product    Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, email])
  @@unique([productId, phone])
  @@index([productId])
  @@index([notifiedAt])
  @@map("stock_notifications")
}

// ─── Staff password reset ────────────────────────────────────────────────

/// Single-use password-reset tokens for the /forgot-password flow.
model PasswordReset {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  token      String    @unique
  expiresAt  DateTime  @map("expires_at") @db.Timestamptz
  usedAt     DateTime? @map("used_at") @db.Timestamptz
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz

  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("password_resets")
}

// ─── Business / site settings ─────────────────────────────────────────────
// Single row (key = "default"). Editable from /admin/settings.
// Env vars serve as the hard fallback when the row doesn't exist yet.

model SiteSettings {
  key              String   @id @default("default")
  storeName        String   @default("Avmall") @map("store_name")
  storeEmail       String   @default("hello@avmall.com.ng") @map("store_email")
  storePhone       String   @default("+234 803 421 7790") @map("store_phone")
  storeWhatsapp    String   @default("+2348034217790") @map("store_whatsapp")
  storeAddress     String   @default("14 Bourdillon Road, Ikoyi, Lagos") @map("store_address")
  /// Fallback bank account shown when Nuqood is not configured
  bankNumber       String?  @map("bank_number")
  bankAccountName  String?  @map("bank_account_name")
  bankName         String?  @map("bank_name")
  /// Return policy window in days (default 14)
  returnWindowDays Int      @default(14) @map("return_window_days")
  updatedAt        DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@map("site_settings")
}

// ─── Pending checkout sessions (bank-transfer, pre-order-creation) ───────
//
// Created when the customer clicks "Pay" for a Nuqood bank transfer.
// No Order row exists until the Nuqood webhook fires confirming payment.
// Expires in 30 minutes (matching Nuqood's dynamic account window).

model PendingCheckout {
  id          String   @id @default(uuid()) @db.Uuid
  /// Nuqood `ref` from get_dynamic_account — matches webhook transaction_reference.
  nuqoodRef   String   @unique @map("nuqood_ref")
  /// PalmPay virtual account number assigned by Nuqood.
  bankNumber  String   @map("bank_number")
  bankName    String   @map("bank_name")
  bankAccount String   @map("bank_account")
  amountKobo  BigInt   @map("amount_kobo")
  expiresAt   DateTime @map("expires_at") @db.Timestamptz
  /// Serialised cart items: [{ productId, variantId, quantity }]
  items       Json
  contact     Json
  shipping    Json
  couponCode  String?  @map("coupon_code")
  /// "pending" | "paid" | "expired"
  status      String   @default("pending")
  /// Set by webhook handler when order is created.
  orderId     String?  @map("order_id") @db.Uuid
  orderNumber String?  @map("order_number")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@index([nuqoodRef])
  @@index([bankNumber])
  @@index([expiresAt])
  @@map("pending_checkouts")
}

// ─── Idempotency keys ────────────────────────────────────────────────────

model IdempotencyKey {
  key         String   @id
  bodyHash    String   @map("body_hash")
  /// JSON-serialised response to replay on retry.
  response    Json
  statusCode  Int      @map("status_code")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@index([createdAt])
  @@map("idempotency_keys")
}
