# ─── Database ────────────────────────────────────────────────────────────
DATABASE_URL=
DIRECT_URL=

# ─── Auth ────────────────────────────────────────────────────────────────
NEXTAUTH_SECRET=
NEXTAUTH_URL=

# ─── Cloudflare R2 ───────────────────────────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# ─── Payments (Nuqood) ───────────────────────────────────────────────────
# All three keys required for live card/bank-transfer payments.
# Get them from your Nuqood merchant dashboard → Settings → API Keys.
NUQOOD_API_KEY=              # starts with "APIKEY-..."
NUQOOD_SECRET_KEY=           # starts with "SECKEY-..."
NUQOOD_BUSINESS_CODE=        # your merchant business code
# Optional: Nuqood sandbox base URL (leave blank to use https://nuqood.ng)
NUQOOD_API_BASE=
# Generate a random 32-char secret. Embedded in the callback URL as ?token=…
# so inbound webhooks can be validated without HMAC (Nuqood doesn't sign them).
NUQOOD_WEBHOOK_SECRET=

# ─── Fallback bank transfer (used when Nuqood is not configured) ──────────
# Shown to customers who choose "Bank transfer" until Nuqood is live.
BUSINESS_BANK_NUMBER=
BUSINESS_BANK_NAME=
BUSINESS_BANK=

# ─── WhatsApp (Meta Cloud API) ───────────────────────────────────────────
META_WA_TOKEN=
META_WA_PHONE_NUMBER_ID=
META_WA_VERIFY_TOKEN=

# ─── AI / LLM ────────────────────────────────────────────────────────────
OPENAI_API_KEY=
DEEPSEEK_API_KEY=

# ─── Email (Resend) ──────────────────────────────────────────────────────
RESEND_API_KEY=
# Optional sender override. Defaults to "Almubaarak Variety Mall
# <noreply@avmall.com.ng>" (the verified domain) — only set this to use a
# different verified address, e.g. EMAIL_FROM="Avmall <orders@avmall.com.ng>".
EMAIL_FROM=

# ─── SMS (Nigerian providers) ────────────────────────────────────────────
TERMII_API_KEY=
AFRICAS_TALKING_API_KEY=
AFRICAS_TALKING_USERNAME=

# ─── Cache / Queues (Upstash Redis) ──────────────────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── Observability ───────────────────────────────────────────────────────
SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=
AXIOM_TOKEN=
